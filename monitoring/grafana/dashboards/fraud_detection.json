{
    "__inputs": [],
    "__requires": [
        {
            "type": "grafana",
            "id": "grafana",
            "name": "Grafana",
            "version": "9.0.0"
        },
        {
            "type": "datasource",
            "id": "prometheus",
            "name": "Prometheus",
            "version": "1.0.0"
        }
    ],
    "annotations": {
        "list": []
    },
    "description": "Real-time monitoring for the fraud detection inference server. Shows request throughput, latency, fraud score distribution, and error rates.",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "id": 1,
            "title": "Requests per Second",
            "description": "Rate of prediction requests over the last 5 minutes. Sudden drops indicate the server is down or not receiving traffic.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "reqps",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 100
                            },
                            {
                                "color": "red",
                                "value": 500
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "calcs": [
                        "mean",
                        "max"
                    ],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(fraud_requests_total[5m])",
                    "legendFormat": "{{endpoint}} ({{status}})",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 2,
            "title": "Request Latency — P50 / P95 / P99",
            "description": "Prediction latency percentiles. P95 > 500ms means most users experience slow responses. P99 > 1s indicates serious performance issues.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "s",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "calcs": [
                        "mean",
                        "max"
                    ],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.50, rate(fraud_request_latency_seconds_bucket[5m]))",
                    "legendFormat": "P50 {{endpoint}}",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, rate(fraud_request_latency_seconds_bucket[5m]))",
                    "legendFormat": "P95 {{endpoint}}",
                    "refId": "B"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.99, rate(fraud_request_latency_seconds_bucket[5m]))",
                    "legendFormat": "P99 {{endpoint}}",
                    "refId": "C"
                }
            ]
        },
        {
            "id": 3,
            "title": "Fraud Detection Rate",
            "description": "Fraction of transactions flagged as fraud. Sudden spikes or drops are early warning signs of model drift or data pipeline issues.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.10
                            },
                            {
                                "color": "red",
                                "value": 0.25
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "calcs": [
                        "mean",
                        "last"
                    ],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(fraud_detections_total[5m]) / rate(fraud_requests_total[5m])",
                    "legendFormat": "Fraud rate {{endpoint}}",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 4,
            "title": "Fraud Score Distribution",
            "description": "Distribution of fraud probability scores output by the model. A healthy system shows most scores near 0 with a small tail near 1. Distribution shift is an early warning of model drift.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "calcs": [
                        "mean"
                    ],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.50, rate(fraud_score_distribution_bucket[5m]))",
                    "legendFormat": "Median score",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.90, rate(fraud_score_distribution_bucket[5m]))",
                    "legendFormat": "P90 score",
                    "refId": "B"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.99, rate(fraud_score_distribution_bucket[5m]))",
                    "legendFormat": "P99 score",
                    "refId": "C"
                }
            ]
        },
        {
            "id": 5,
            "title": "Total Requests (last 1h)",
            "description": "Total prediction requests in the last hour.",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "increase(fraud_requests_total[1h])",
                    "legendFormat": "Requests",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 6,
            "title": "Total Fraud Detected (last 1h)",
            "description": "Transactions flagged as fraud in the last hour.",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 100
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "increase(fraud_detections_total[1h])",
                    "legendFormat": "Fraud detected",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 7,
            "title": "Error Rate",
            "description": "Prediction errors per second. Any sustained error rate above 0 warrants immediate investigation.",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "increase(fraud_errors_total[1h])",
                    "legendFormat": "Errors",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 8,
            "title": "Active Model Version",
            "description": "Which model version is currently serving predictions. Changes when a new model is promoted to Production.",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "none"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "fraud_model_version",
                    "legendFormat": "Model version",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 9,
            "title": "Error Breakdown by Type",
            "description": "Errors broken down by type. model_not_loaded means startup issues. prediction_error means bugs in the pipeline.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "calcs": [
                        "sum"
                    ],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "rate(fraud_errors_total[5m])",
                    "legendFormat": "{{error_type}} on {{endpoint}}",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 10,
            "title": "Active Requests",
            "description": "Number of requests currently being processed. Should be near 0 between bursts. Sustained high values indicate the server is overloaded.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "short",
                    "min": 0
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "calcs": [
                        "max"
                    ],
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "fraud_active_requests",
                    "legendFormat": "Active {{endpoint}}",
                    "refId": "A"
                }
            ]
        }
    ],
    "refresh": "15s",
    "schemaVersion": 37,
    "style": "dark",
    "tags": [
        "fraud",
        "ml",
        "inference"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "browser",
    "title": "Fraud Detection — Inference Server",
    "uid": "fraud-detection-monitoring",
    "version": 1
}
